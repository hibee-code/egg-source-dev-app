# ─── Server ────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ──────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/egg-source-dev

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
